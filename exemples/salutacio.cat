(definir saluda-en
  (funció (idioma)
    (si (= idioma "català")
        (funció (nom) (escriure "Hola," nom))
        (si (= idioma "anglès")
            (funció (nom) (escriure "Hello," nom))
            (funció (nom) (escriure "Ei," nom))))))

(definir saluda-català (saluda-en "català"))
(saluda-català "Maria")
(saluda-català "Joan")
